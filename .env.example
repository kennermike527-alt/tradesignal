# Required: Postgres connection string
# Local default example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tradesignal?schema=public"
# Vercel/managed DB example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tradesignal?sslmode=require"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tradesignal?schema=public"

# Optional for providers that split pooled/direct URLs
DIRECT_URL=""

# Optional OpenAI summaries (fallback heuristic is used if missing)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# API security for /api/ingest in non-development mode
INGESTION_SECRET="change-me"

# Runtime provider mode (current provider is mock for demo ingestion)
SOCIAL_PROVIDER_MODE="mock"

# Budget guard (targets max spend and blocks over-budget cadences)
INGEST_MONTHLY_BUDGET_USD="350"
INGEST_CADENCE_MINUTES="60"
INGEST_POST_READ_COST_USD="0.005"
INGEST_USER_READ_COST_USD="0.01"
INGEST_EST_POSTS_PER_ACCOUNT_PER_RUN="10"
INGEST_EST_USER_READS_PER_ACCOUNT_PER_RUN="0"

# Context narrative summarization (cluster + global command layer)
CONTEXT_SUMMARY_PROVIDER="openai"
CONTEXT_SUMMARY_MODEL="gpt-4o-mini"
CONTEXT_SUMMARY_REFRESH_MINUTES="90"
CONTEXT_SUMMARY_MAX_POSTS="300"
